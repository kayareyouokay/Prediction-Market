generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String         @id         @default(uuid())
  address    String         @unique
  usdBalance Int
  orders     OrderHistory[]
  positions  Position[]
}

model Market {
  id                    String         @id          @default(uuid())
  title                 String
  description           String
  resolutionDescription String
  yesOrderbook          Json
  noOrderbook           Json
  totalQty              Int
  resolution            PositionType?
  orders                OrderHistory[]
  positions             Position[]
}

model Position {
  id       String       @id @default(uuid())
  userId   String
  marketId String
  type     PositionType
  market   Market       @relation(fields: [marketId], references: [id])
  user     User         @relation(fields: [userId], references: [id])
  qty      Int
  @@unique([userId, marketId, type])
}

model OrderHistory {
  id        String    @id @default(uuid())
  orderType OrderType
  qty       Int
  price     Int
  userId    String
  marketId  String
  market    Market    @relation(fields: [marketId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
}

enum OrderType {
  Buy
  Sell
  Split
  Merge
}

enum PositionType {
  Yes
  No
}
