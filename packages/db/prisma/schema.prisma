// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String      @id       @default(uuid())
  address       String
  usdBalance    Int   // $100.11 => 10011 assume a decimal of 2 for fiat balances
  positions     Position[]
  orders        OrderHistory[]
}

model Market {
  id                       String      @id       @default(uuid())
  title                    String
  description              String
  resolutionDescription    String
  yesOrderbook             Json
  noOrderbook              Json
  totalQty                 Int
  positions                Position[]
  orders                   OrderHistory[]
  resolution               PositionType?
}

model Position {
  id            String      @id       @default(uuid())
  userId        String
  marketId      String
  type          PositionType
  user          User        @relation(fields: [userId], references: [id])
  market        Market      @relation(fields: [marketId], references: [id])
}

model OrderHistory {
  id            String      @id       @default(uuid())
  orderType     OrderType
  qty           Int
  price         Int   // 0.01 => 0.99 (1-100)
  userId        String
  marketId      String
  user          User        @relation(fields: [userId], references: [id])
  market        Market      @relation(fields: [marketId], references: [id])
}

enum OrderType {
  Buy
  Sell
  Split
  Merge
}

enum PositionType {
  Yes
  No
}

